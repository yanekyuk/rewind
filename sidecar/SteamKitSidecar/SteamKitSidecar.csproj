<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>SteamKitSidecar</AssemblyName>
    <RootNamespace>SteamKitSidecar</RootNamespace>
    <Version>0.1.0</Version>
    <Description>SteamKit-based sidecar for Rewind game downgrader</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- SteamKit2 for Steam interaction -->
    <PackageReference Include="SteamKit2" Version="3.4.0" />
  </ItemGroup>

</Project>
